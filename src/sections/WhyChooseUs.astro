---
---

<section class="py-20 bg-white">
  <div class="container-main">
    <div class="grid md:grid-cols-[1.2fr_1fr] gap-16 items-start">
      <div>
        <div class="accent-line" />
        <h2 class="font-belleza text-2xl md:text-3xl mb-10 tracking-[0.1em] uppercase">Why Choose Us?</h2>
        <div class="space-y-0">
          {[
            { title: "Luxury Travel", desc: "We provide exclusive safari experiences that prioritize your comfort and offer a touch of luxury in every journey." },
            { title: "Personalized Itineraries", desc: "Each itinerary is meticulously crafted to reflect your unique preferences and interests, ensuring a memorable adventure." },
            { title: "Local Expertise", desc: "Our extensive network and local knowledge guarantee exceptional service and experiences tailored to the beauty of Africa." },
          ].map((item, i) => (
            <div class={`flex gap-4 py-6 ${i < 2 ? "border-b border-gray-200" : ""}`}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4a5c2a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
              </svg>
              <div>
                <h3 class="font-belleza text-base tracking-wide mb-2">{item.title}</h3>
                <p class="text-[#555] text-sm leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <img src="/images/leopard-tree-safari-simbali-wild-safaris.jpg" alt="Leopard" class="rounded-xl h-[480px] object-cover w-full" />
    </div>
  </div>
</section>
