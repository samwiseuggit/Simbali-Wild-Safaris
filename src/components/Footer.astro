---
---

<!-- Footer CTA Banner -->
<section class="relative py-24 text-center overflow-hidden">
  <img src="/images/footer-sunset.png" alt="" class="absolute inset-0 w-full h-full object-cover" style="object-position: center top;" />
  <div class="absolute inset-0 bg-black/60" />
  <div class="relative z-10 container-main">
    <div class="w-9 h-0.5 bg-olive mx-auto mb-6" />
    <h2 class="font-belleza text-3xl md:text-4xl text-white mb-4 tracking-[0.1em] uppercase">Ready For Your Next Adventure?</h2>
    <p class="text-white/75 text-[15px] mb-8 max-w-[500px] mx-auto leading-relaxed">Contact us today to start planning your dream safari in the breathtaking landscapes of Africa!</p>
    <a href="/contact" class="btn-primary inline-flex">Start Your Journey</a>
  </div>
</section>

<!-- Footer Bar -->
<footer class="bg-white border-t border-gray-100 py-4">
  <div class="container-main flex items-center justify-between gap-3">
    <div class="flex items-center gap-6">
      <!-- Scroll to top button -->
      <button id="scroll-top" class="w-10 h-10 bg-olive text-white rounded flex items-center justify-center hover:bg-olive-dark transition-colors" aria-label="Scroll to top">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 15l-6-6-6 6" />
        </svg>
      </button>
      <div class="flex gap-7">
        <a href="/about" class="text-[#444] text-sm hover:text-olive transition-colors">About</a>
        <a href="/services" class="text-[#444] text-sm hover:text-olive transition-colors">Services</a>
        <a href="/blog" class="text-[#444] text-sm hover:text-olive transition-colors">Blog</a>
      </div>
    </div>
    <div class="text-[#999] text-xs">Copyright &copy; 2025 Simbali Wild Safari</div>
  </div>
</footer>

<script>
  document.getElementById('scroll-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
