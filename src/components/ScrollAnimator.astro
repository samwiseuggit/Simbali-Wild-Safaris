<script>
  (function() {
    function initAnimations() {
      // 1. Add JS class to enable animations (elements were visible by default)
      document.documentElement.classList.add('js-animations-enabled');

      // 2. Set up IntersectionObserver for scroll-triggered reveals
      var observer = new IntersectionObserver(
        function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );

      // 3. Observe all animated elements
      var animElements = document.querySelectorAll(
        '.anim-fade-up, .anim-fade-down, .anim-fade-left, .anim-fade-right, .anim-scale-in'
      );
      animElements.forEach(function(el) { observer.observe(el); });
    }

    // Run immediately if DOM is ready, otherwise wait
    if (document.readyState !== 'loading') {
      initAnimations();
    } else {
      document.addEventListener('DOMContentLoaded', initAnimations);
    }
  })();
</script>
