---
import MainLayout from '../../layouts/MainLayout.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';

const post = { slug: 'lake-naivasha-kenya-boat-safari-birdwatching', title: "Lake Naivasha: Kenya's Highest Lake and a Birdwatcher's Paradise", description: "Discover Lake Naivasha, Kenya's highest lake: boat safaris among hippos, 400+ bird species, Crescent Island walks and Hell's Gate adventures.", img: '/images/serene-lakeside-mountain-landscape_blog.jpg', imgAlt: 'Peaceful Rift Valley lakeside landscape evoking Lake Naivasha at dawn', date: 'July 18, 2026', readTime: '10 min read', cat: 'Destinations' };
const sections = [
  ['A Softer Safari Rhythm', 'Lake Naivasha gives a Kenyan safari time to breathe. Water replaces dust, reflections replace horizons, and the sound of fish eagles carries across the morning air.'],
  ['Boat Safaris and Hippos', 'A guided boat safari is the essential experience. From the water you can watch hippos at a safe distance, cormorants drying their wings, and fish eagles scanning the shoreline.'],
  ['Birdwatching Highlights', 'More than 400 bird species have been recorded around Naivasha, including fish eagles, kingfishers, herons, pelicans, jacanas, weavers, and seasonal migrants.'],
  ['Crescent Island and Hell\'s Gate', 'Crescent Island offers gentle walking among giraffes, zebras, impalas, and waterbuck, while nearby Hell\'s Gate adds cliffs, cycling, geothermal drama, and active Rift Valley scenery.'],
  ['Where It Fits', 'Naivasha works beautifully between Ol Pejeta, Amboseli, Lake Nakuru, and the Maasai Mara, especially for families and honeymooners who want a calm lakeside pause.'],
];
---
<MainLayout title={`${post.title} | Simbali Wild Safaris Blog`} description={post.description}>
  <Fragment slot="head"><link rel="canonical" href={`https://simbaliwildsafaris.com/blog/${post.slug}/`} /><meta property="og:title" content={`${post.title} | Simbali Wild Safaris`} /><meta property="og:description" content={post.description} /><meta property="og:image" content={`https://simbaliwildsafaris.com${post.img}`} /></Fragment>
  <section class="relative overflow-hidden"><div class="absolute inset-0"><OptimizedImage src={post.img} alt={post.imgAlt} class="w-full h-full object-cover" loading="eager" /><div class="absolute inset-0 bg-black/50" /></div><div class="relative container-main py-20 md:py-28 text-center max-w-4xl"><div class="text-white/70 text-sm mb-4">{post.cat} / {post.date} / {post.readTime}</div><h1 class="font-belleza text-3xl md:text-5xl tracking-[0.08em] uppercase text-white leading-tight mb-4">{post.title}</h1><p class="text-white/80 text-base md:text-lg max-w-2xl mx-auto leading-relaxed">{post.description}</p></div></section>
  <section class="py-16 bg-white"><article class="container-main max-w-4xl prose-blog"><p class="text-[#444] leading-[1.8] mb-5 text-[15px]">At dawn on Lake Naivasha, mist lifts from the freshwater and safari begins quietly. It is restorative, bird-rich, and perfectly placed within a wider Kenya journey.</p>{sections.map(([title, body]) => (<section><h2 class="font-belleza text-2xl md:text-3xl tracking-[0.08em] uppercase mt-12 mb-5 text-[#1a1a1a]">{title}</h2><p class="text-[#444] leading-[1.8] mb-5 text-[15px]">{body}</p></section>))}<p class="text-[#444] leading-[1.8] mb-5 text-[15px]">Explore Naivasha on our Kenya family and honeymoon journeys, or <a href="/contact" class="text-olive underline font-semibold">contact Simbali Wild Safaris</a> for a bespoke lakeside safari.</p></article></section>
</MainLayout>
