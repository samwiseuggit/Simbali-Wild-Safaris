---
import MainLayout from '../../layouts/MainLayout.astro';

export function getStaticPaths() {
  const posts = {
    "wonders-of-kenyas-great-rift-valley": {
      title: "Great Rift Valley Kenya: Nature, Culture & Adventure",
      img: "/images/serene-lakeside-mountain-landscape_blog.jpg",
    },
    "east-africa-birding-guide": {
      title: "East Africa Birding Guide: Best Spots, Species & Travel Tips",
      img: "/images/raptor-bird-flying-clear-sky_blog.jpg",
    },
    "wildebeest-migration-an-epic-safari-adventure": {
      title: "Wildebeest Migration: An Epic Safari Adventure",
      img: "/images/wildebeest-river-crossing-safari-migration_blog.jpg",
    },
  };
  return Object.keys(posts).map(slug => ({ params: { slug }, props: { post: posts[slug] } }));
}

const blogContent: Record<string, string> = {
  "wonders-of-kenyas-great-rift-valley": `<p>The <strong>Great Rift Valley Kenya</strong> is one of the most incredible places on Earth. It's part of a massive crack in the planet's surface that runs from the Middle East all the way down through Eastern Africa. The Kenyan part of the valley is especially beautiful—and full of surprises.</p><p>Here, you'll find tall cliffs called escarpments, wide lakes, hot springs, volcanoes, and endless plains. It's a place where nature tells the story of our planet's past—and gives you plenty to explore today.</p><h2>Nature's Artwork: Lakes, Volcanoes, and More</h2><p>The landscapes of the Great Rift Valley Kenya are full of variety:</p><ul><li><strong>Lake Naivasha</strong> is peaceful and great for boat rides.</li><li><strong>Lake Nakuru</strong> often turns pink from thousands of flamingos.</li><li><strong>Lake Bogoria</strong> is known for its hot springs and geysers.</li><li><strong>Mount Longonot</strong>, an extinct volcano, offers amazing views after a good hike.</li><li><strong>Hell's Gate National Park</strong> has deep gorges and steam vents—and you can walk or cycle among wild animals!</li></ul><h2>Wildlife You Won't Forget</h2><p>While the Great Rift Valley Kenya isn't a traditional safari park, it's still packed with wildlife. Around the lakes, you'll see hippos, buffalo, zebras, giraffes, and even rhinos. Birdwatchers love this area because it's home to over 400 bird species—including pelicans, eagles, and the famous flamingos.</p><h2>Culture and People</h2><p>The valley isn't just about nature. It's also home to many Kenyan communities. The Maasai people, known for their colorful dress and rich traditions, live in parts of the Rift Valley. Visiting their villages gives you a chance to learn about their way of life, taste local food, and enjoy traditional music and dance.</p><h2>Adventure Awaits</h2><p>Whether you enjoy hiking, biking, boat rides, or photography, the Great Rift Valley Kenya has something for you. You can camp under the stars, relax by a lake, or climb a volcano for sunrise. It's a perfect stop on any Kenyan safari.</p><h2>Plan Your Visit</h2><p>The Great Rift Valley Kenya is easy to reach from Nairobi and fits well into most safari itineraries. At Simbali Wild Safaris, we can help you plan the perfect trip—whether you want a quick day visit or a longer adventure exploring the lakes and parks.</p><p><strong>Contact us today</strong> and let us take you to one of Kenya's most amazing natural wonders!</p>`,
  "east-africa-birding-guide": `<p>A Birdwatcher's Guide to East Africa: Unveiling the Region's Avian Treasures. East Africa is a birdwatcher's paradise, bursting with life and color. From the vast savannas of Kenya to the lush forests of Uganda, this region is home to over 1,000 bird species. Whether you're a seasoned birder or a curious beginner, East Africa offers unforgettable avian encounters.</p><h2>Why East Africa for Birding?</h2><p>East Africa boasts diverse habitats—wetlands, forests, mountains, and grasslands—each supporting unique bird species. The region's equatorial climate ensures year-round birding opportunities, with migratory species adding to the excitement during certain seasons.</p><h2>Top Birding Destinations</h2><h3>Kenya</h3><ul><li><strong>Maasai Mara:</strong> Over 470 species including the lilac-breasted roller and secretary bird.</li><li><strong>Lake Nakuru:</strong> Famous for millions of flamingos and pelicans.</li><li><strong>Kakamega Forest:</strong> A rainforest haven with unique species like the great blue turaco.</li><li><strong>Amboseli National Park:</strong> Spot waterbirds with Mount Kilimanjaro as your backdrop.</li></ul><h3>Tanzania</h3><ul><li><strong>Serengeti National Park:</strong> Raptors, ostriches, and the endemic grey-breasted spurfowl.</li><li><strong>Ngorongoro Crater:</strong> A self-contained ecosystem with flamingos, crowned cranes, and more.</li><li><strong>Arusha National Park:</strong> Over 400 species in a compact, diverse park.</li></ul><h3>Uganda</h3><ul><li><strong>Bwindi Impenetrable Forest:</strong> Home to 23 Albertine Rift endemics.</li><li><strong>Queen Elizabeth National Park:</strong> Over 600 species—the highest in any African park!</li><li><strong>Murchison Falls National Park:</strong> Shoebill stork sightings and riverine birds.</li></ul><h2>Must-See Bird Species</h2><ul><li><strong>Shoebill Stork</strong> – A prehistoric-looking giant found in Uganda's wetlands.</li><li><strong>African Fish Eagle</strong> – The iconic voice of African waterways.</li><li><strong>Lilac-breasted Roller</strong> – Kenya's national bird, a rainbow of colors.</li><li><strong>Secretary Bird</strong> – A tall, elegant hunter of the savanna.</li><li><strong>Grey Crowned Crane</strong> – Uganda's national bird, graceful and endangered.</li><li><strong>Great Blue Turaco</strong> – A spectacular forest bird with vibrant plumage.</li></ul><h2>Plan Your Birding Safari</h2><p>At Simbali Wild Safaris, we specialize in tailor-made birding safaris across East Africa. Our expert guides know the best spots and can help you tick off your target species. <a href="/contact.html" class="text-olive underline">Contact us</a> to plan your ultimate birding adventure!</p>`,
  "wildebeest-migration-an-epic-safari-adventure": `<p>The <strong>Great Wildebeest Migration</strong> is one of the most spectacular wildlife events on Earth. Every year, over 1.5 million wildebeest, accompanied by hundreds of thousands of zebras and gazelles, thunder across the Serengeti-Maasai Mara ecosystem in a never-ending cycle of life, death, and rebirth.</p><h2>The Journey of a Lifetime</h2><p>The migration follows a roughly circular route spanning approximately 1,800 miles. Driven by the search for fresh grazing and water, the herds move in a clockwise pattern through Tanzania's Serengeti and Kenya's Maasai Mara, facing countless challenges along the way.</p><h2>Best Places to Witness the Migration</h2><h3>Serengeti National Park, Tanzania</h3><ul><li><strong>January-March:</strong> Calving season in the southern Serengeti. Over 8,000 calves are born daily during the peak.</li><li><strong>April-June:</strong> The herds move north through the central and western corridors.</li><li><strong>July-October:</strong> The dramatic Mara River crossings in the northern Serengeti.</li></ul><h3>Maasai Mara National Reserve, Kenya</h3><ul><li><strong>July-October:</strong> Herds cross the Mara River into Kenya, creating the most dramatic wildlife spectacles.</li><li><strong>September-October:</strong> Prime time for river crossings and predator action.</li><li><strong>November:</strong> The herds begin their journey back to the Serengeti.</li></ul><h2>The Mara River Crossings</h2><p>The Mara River crossings are the highlight of the migration. As wildebeest plunge into crocodile-infested waters, the drama unfolds—some make it across, others fall prey to massive Nile crocodiles or drown in the stampede. It's nature at its most raw and captivating.</p><h2>Predators of the Migration</h2><p>The migration attracts Africa's most iconic predators:</p><ul><li><strong>Lions:</strong> The Mara prides are famous for their hunting prowess during migration season.</li><li><strong>Cheetahs:</strong> These speedsters take advantage of the abundance of prey.</li><li><strong>Hyenas:</strong> Scavengers and hunters alike, they follow the herds closely.</li><li><strong>Crocodiles:</strong> The ancient predators of the Mara River lie in wait for the crossings.</li></ul><h2>Responsible Tourism</h2><p>At Simbali Wild Safaris, we believe in responsible tourism that respects wildlife and supports local communities. We follow strict guidelines to minimize our impact, support conservation efforts, and ensure that the migration can be enjoyed by future generations.</p><h2>Plan Your Migration Safari</h2><p>Witnessing the Great Wildebeest Migration is a bucket-list experience. Let Simbali Wild Safaris craft your perfect migration safari—whether you want to see the calving season, the dramatic river crossings, or the full circular journey. <a href="/contact.html" class="text-olive underline">Contact us today</a> to start planning!</p>`,
};

const { slug } = Astro.params;
const { post } = Astro.props;
const content = blogContent[slug] || "";
---

<MainLayout title={`${post.title} | Simbali Wild Safaris Blog`}>
  <section class="py-10 bg-sage/40 min-h-[80vh]">
    <div class="container-main max-w-3xl">
      <article class="bg-white rounded-2xl p-8 md:p-12">
        <div class="text-center mb-8">
          <div class="text-[#999] text-sm mb-4">By Sam / April 17, 2025</div>
          <h1 class="font-belleza text-3xl md:text-4xl leading-snug tracking-[0.1em] uppercase">{post.title}</h1>
        </div>
        <img src={post.img} alt="" class="w-full rounded-xl mb-8 h-[380px] object-cover" />
        <div class="prose-blog" set:html={content} />
      </article>
    </div>
  </section>
</MainLayout>
