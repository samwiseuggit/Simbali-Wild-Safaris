---

<MainLayout title="Contact | Simbali Wild Safaris">
  <section class="bg-sage/60 py-20 pb-16">
    <div class="container-main grid md:grid-cols-2 gap-12 items-center">
      <div>
        <div class="accent-line" />
        <h1 class="font-belleza text-4xl md:text-5xl leading-tight tracking-[0.1em] uppercase">Get in Touch with Simbali Wild Safaris</h1>
      </div>
      <img src="/images/giraffes-savanna-safari-simbali-wild-safaris.jpg" alt="Giraffes" class="rounded-2xl h-[380px] object-cover w-full" />
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container-main max-w-4xl">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-sage/50 rounded-2xl p-9">
          <label class="text-xs text-[#666] uppercase tracking-wider font-medium block mb-2">Phone</label>
          <div class="text-xl text-[#1a1a1a] font-medium">+254 713 855 818</div>
        </div>
        <div class="bg-white border border-gray-200 rounded-2xl p-9">
          <label class="text-xs text-[#666] uppercase tracking-wider font-medium block mb-2">Email</label>
          <div class="text-xl text-[#1a1a1a] font-medium"><a href="mailto:info@simbaliwildlisafaris.com" class="text-olive underline">info@simbaliwildlisafaris.com</a></div>
        </div>
        <div class="bg-white border border-gray-200 rounded-2xl p-9">
          <label class="text-xs text-[#666] uppercase tracking-wider font-medium block mb-2">Address</label>
          <div class="text-xl text-[#1a1a1a] font-medium"><a href="https://simbaliwildsafaris.com" class="text-olive underline">www.simbaliwildsafaris.com</a></div>
        </div>
        <div class="bg-sage/50 rounded-2xl p-9">
          <label class="text-xs text-[#666] uppercase tracking-wider font-medium block mb-2">Social Media</label>
          <div class="flex gap-5">
            {socialIcons.map(s => (
              <a href="#" aria-label={s.label} class="text-[#1a1a1a]/70 hover:text-olive transition-colors">
                <svg viewBox="0 0 24 24" class="w-6 h-6 fill-current"><path d={s.path} /></svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-sage/40">
    <div class="container-main max-w-4xl">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <div class="accent-line" />
          <h2 class="font-belleza text-3xl mb-4 tracking-[0.1em] uppercase leading-snug">We&apos;d Love to Hear from You and Assist</h2>
          <p class="text-[#555] text-[15px] leading-relaxed">Reach out to us for tailored safari experiences and unforgettable adventures. We respond promptly to all inquiries!</p>
        </div>
        <form class="space-y-4" onsubmit="event.preventDefault(); alert('Thank you! We will get back to you soon.');">
          <div class="grid grid-cols-2 gap-4">
            <input type="text" placeholder="First Name" required class="w-full px-4 py-3.5 bg-white border border-gray-200 rounded-lg text-sm outline-none focus:ring-1 focus:ring-olive" />
            <input type="text" placeholder="Last Name" required class="w-full px-4 py-3.5 bg-white border border-gray-200 rounded-lg text-sm outline-none focus:ring-1 focus:ring-olive" />
          </div>
          <input type="email" placeholder="Email Address" required class="w-full px-4 py-3.5 bg-white border border-gray-200 rounded-lg text-sm outline-none focus:ring-1 focus:ring-olive" />
          <textarea placeholder="Type your message" required rows="5" class="w-full px-4 py-3.5 bg-white border border-gray-200 rounded-lg text-sm outline-none focus:ring-1 focus:ring-olive resize-y"></textarea>
          <button type="submit" class="btn-primary">Submit</button>
        </form>
      </div>
    </div>
  </section>

  <section class="h-[400px] bg-gray-200">
    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d255281.19891906833!2d36.68248865!3d-1.3028611!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x182f1172d84d49a7%3A0xf7cf0254b297924c!2sNairobi%2C%20Kenya!5e0!3m2!1sen!2sus!4v1699000000000!5m2!1sen!2sus" allowfullscreen loading="lazy" title="Simbali Wild Safaris Location" class="w-full h-full border-0"></iframe>
  </section>
</MainLayout>
