---
import MainLayout from '../layouts/MainLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { itineraries } from '../data/itineraries';

const countryImages = {
  Kenya: "/images/giraffes-savanna-safari-simbali-wild-safaris.jpg",
  Tanzania: "/images/zebras-savanna-safari-simbali-wild-safaris.jpg",
  Uganda: "/images/uganda-safari.jpg",
  Rwanda: "/images/rwanda-safari.jpg",
  Burundi: "/images/burundi-safari.jpg",
};

const itinImages = {
  "kenya-honeymoon-8": "/images/itin-kenya-honeymoon.jpg",
  "kenya-family-8": "/images/itin-kenya-family.jpg",
  "kenya-tanzania-family-11": "/images/itin-kenya-tanzania-family.jpg",
  "tanzania-family-8": "/images/itin-tanzania-family.jpg",
  "tanzania-honeymoon-8": "/images/itin-tanzania-honeymoon.jpg",
};

const countries = [
  { name: "Kenya", hasItins: true },
  { name: "Tanzania", hasItins: true },
  { name: "Uganda", hasItins: false },
  { name: "Rwanda", hasItins: false },
  { name: "Burundi", hasItins: false },
];
---

<MainLayout title="Safari Itineraries | Simbali Wild Safaris">
  {/* Hero */}
  <section class="bg-sage/60 py-20 pb-16">
    <div class="container-main anim-fade-up">
      <div class="accent-line" />
      <h1 class="font-belleza text-4xl md:text-5xl tracking-[0.1em] uppercase leading-tight">Safari Itineraries</h1>
      <p class="text-[#555] text-[15px] leading-relaxed mt-4 max-w-2xl">Explore our carefully curated safari itineraries through East Africa&apos;s most spectacular destinations.</p>
    </div>
  </section>

  {/* Countries */}
  <section class="py-16 bg-white">
    <div class="container-main max-w-5xl">
      {countries.map((c, ci) => {
        const countryItins = itineraries.filter(i => i.country === c.name);
        return (
          <details class="mb-6 group" style={`transition-delay: ${ci * 100}ms`} open={true}>
            {/* Country header */}
            <summary class="flex items-center gap-4 px-6 py-5 bg-olive rounded-xl cursor-pointer list-none hover:bg-olive-dark transition-colors hover:shadow-md">
              <img src={countryImages[c.name]} alt={c.name} class="w-12 h-12 rounded-full object-cover border-2 border-white/30 flex-shrink-0" />
              <div class="flex items-center gap-3 flex-wrap">
                <h2 class="font-belleza text-2xl md:text-3xl tracking-[0.1em] uppercase text-white">{c.name}</h2>
                {c.hasItins && <span class="text-sm text-white/80 bg-white/20 px-3 py-1 rounded-full">{countryItins.length} Itineraries</span>}
              </div>
              <svg class="w-6 h-6 text-white/70 ml-auto transition-transform group-open:rotate-180 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}><path d="M6 9l6 6 6-6" /></svg>
            </summary>

            {/* Country content */}
            <div class="pt-4">
              {c.hasItins ? countryItins.map((itin, ii) => (
                <div id={itin.id} class="bg-white rounded-2xl border border-gray-200 overflow-hidden mb-6 scroll-mt-32 shadow-sm hover-lift" style={`transition-delay: ${(ii + 1) * 150}ms`}>
                  {/* Package card */}
                  <div class="flex flex-col md:flex-row md:items-start gap-5 p-6">
                    <div class="flex-shrink-0 hover-zoom rounded-xl">
                      <OptimizedImage src={itinImages[itin.id] || countryImages[c.name]} alt={itin.title} class="w-full md:w-56 h-40 md:h-36 rounded-xl object-cover" loading="lazy" />
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-2 flex-wrap">
                        <span class="inline-block text-[11px] font-semibold uppercase tracking-wider px-3 py-1 rounded-full bg-sage text-olive">{itin.type}</span>
                        <span class="text-xs text-[#999]">{itin.duration}</span>
                      </div>
                      <h3 class="font-belleza text-xl md:text-2xl text-[#1a1a1a] mb-2 leading-tight">{itin.title}</h3>
                      <p class="text-[#555] text-sm leading-relaxed">{itin.description}</p>
                      <div class="flex flex-wrap gap-2 mt-3">
                        {itin.highlights.map(h => <span class="text-xs text-[#555] bg-[#f5f7f3] px-3 py-1.5 rounded-full">{h}</span>)}
                      </div>
                    </div>
                  </div>

                  {/* Expandable day-by-day */}
                  <div class="px-6 pb-6">
                    <details class="group/day border border-gray-200 rounded-xl overflow-hidden">
                      <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none bg-olive/10 hover:bg-olive/20 transition-colors">
                        <div class="flex items-center gap-3">
                          <svg class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                          </svg>
                          <span class="font-belleza text-base md:text-lg tracking-[0.08em] uppercase text-olive font-semibold">View Day-by-Day Itinerary</span>
                        </div>
                        <svg class="w-5 h-5 text-olive transition-transform group-open/day:rotate-180 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}><path d="M6 9l6 6 6-6" /></svg>
                      </summary>
                      <div class="bg-[#f9faf7] rounded-b-xl p-5">
                        {itin.days.map(day => (
                          <div class="flex gap-4 py-4 border-b border-gray-200 last:border-0">
                            <div class="flex-shrink-0 w-14 h-14 rounded-full bg-olive text-white flex items-center justify-center text-base font-semibold">{day.day}</div>
                            <div class="flex-1 min-w-0">
                              <p class="text-[#444] text-sm leading-relaxed mb-3">{day.description}</p>
                              <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-xs text-[#666]">
                                {day.accommodation && day.accommodation !== "No Accommodation" && <div><span class="text-[#999] uppercase tracking-wider text-[10px]">Stay</span><p class="text-[#444] mt-0.5">{day.accommodation}</p></div>}
                                {day.meals && <div><span class="text-[#999] uppercase tracking-wider text-[10px]">Meals</span><p class="text-[#444] mt-0.5">{day.meals}</p></div>}
                                {day.transport && <div><span class="text-[#999] uppercase tracking-wider text-[10px]">Transport</span><p class="text-[#444] mt-0.5">{day.transport}</p></div>}
                                {day.remarks && <div><span class="text-[#999] uppercase tracking-wider text-[10px]">Activity</span><p class="text-[#444] mt-0.5">{day.remarks}</p></div>}
                              </div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </details>

                    {/* Pricing */}
                    {itin.pricingNote && (
                      <div class="bg-sage/30 rounded-xl p-5 mt-4">
                        <h4 class="font-belleza text-base tracking-[0.1em] uppercase mb-3 text-olive font-semibold">Pricing</h4>
                        <p class="text-sm text-[#444]">{itin.pricingNote}</p>
                        {itin.paxRates && itin.paxRates.length > 1 && (
                          <div class="mt-4 grid grid-cols-3 md:grid-cols-6 gap-3">
                            {itin.paxRates.map(r => (
                              <div class="bg-white rounded-lg p-3 text-center border border-gray-100">
                                <div class="text-[11px] text-[#999] uppercase">{r.pax} Pax</div>
                                <div class="text-base font-semibold text-olive">${r.rate.toLocaleString()}</div>
                              </div>
                            ))}
                          </div>
                        )}
                      </div>
                    )}

                    {/* Included/Excluded */}
                    <div class="grid md:grid-cols-2 gap-8 mt-5">
                      <div>
                        <h4 class="font-belleza text-base tracking-[0.1em] uppercase mb-4 text-olive font-semibold">Included</h4>
                        <ul class="space-y-2">
                          {itin.included.map(item => <li class="flex items-start gap-2 text-sm text-[#444]"><span class="text-olive flex-shrink-0 mt-0.5">&#10003;</span>{item}</li>)}
                        </ul>
                      </div>
                      <div>
                        <h4 class="font-belleza text-base tracking-[0.1em] uppercase mb-4 text-[#999] font-semibold">Excluded</h4>
                        <ul class="space-y-2">
                          {itin.excluded.map(item => <li class="flex items-start gap-2 text-sm text-[#777]"><span class="text-[#ccc] flex-shrink-0 mt-0.5">&#10007;</span>{item}</li>)}
                        </ul>
                      </div>
                    </div>
                  </div>
                </div>
              )) : (
                <div class="py-10 px-6 text-center bg-sage/20 rounded-xl anim-fade-up">
                  <img src={countryImages[c.name]} alt={c.name} class="w-16 h-16 rounded-full object-cover mx-auto mb-4 opacity-60" />
                  <h3 class="font-belleza text-lg tracking-[0.1em] uppercase mb-2">{c.name}</h3>
                  <p class="text-sm text-[#999]">Itineraries coming soon</p>
                </div>
              )}
            </div>
          </details>
        );
      })}
    </div>
  </section>
</MainLayout>
